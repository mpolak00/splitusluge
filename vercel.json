{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm build",
  "functions": {
    "api/index.ts": {
      "includeFiles": "dist/public/**"
    }
  },
  "routes": [
    {
      "src": "/((?!assets/|images/|categories/|__manus__/).*)",
      "dest": "/api/index.ts"
    }
  ]
}
